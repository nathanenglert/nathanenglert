---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import LogEntry from '../components/LogEntry.astro';

const entries = await getCollection('log');
// Sort descending by number (newest first)
const sorted = entries.sort((a, b) => b.data.number - a.data.number);
const entryCount = sorted.length;
const paddedCount = String(entryCount).padStart(3, '0');
---
<Base>
  <!-- HEADER -->
  <header class="site-header">
    <a href="#top" class="site-header__name">Nathan Englert</a>
    <nav class="site-header__nav">
      <a href="https://github.com/nathanenglert">GitHub</a>
      <a href="mailto:nenglert@gmail.com">Email</a>
    </nav>
  </header>

  <!-- HERO -->
  <section id="top" class="hero">
    <img
      id="hero-portrait"
      class="hero__portrait"
      src="/avatar.jpeg"
      alt="Nathan Englert"
      width="440"
      height="440"
    />
    <div class="hero__content">
      <div class="hero__kicker">
        <span class="hero__kicker-dot"></span>
        <span>Field notes &middot; est. 2010</span>
      </div>
      <h1 class="hero__h1">
        I'm a systems thinker,<br>a product engineer,<br>and an occasional poet.<br>Staff engineer by day; <em>maker by compulsion</em>.
      </h1>
      <p class="hero__body">
        The log is where the compulsion lands: projects, experiments, the occasional note. Newest first.
      </p>
    </div>
  </section>

  <!-- THE LOG -->
  <section id="log" class="log">
    <div class="log__header">
      <span class="log__header-title">The Log</span>
      <span class="log__header-count">{paddedCount} entries</span>
    </div>

    {sorted.map(entry => (
      <LogEntry
        number={entry.data.number}
        tag={entry.data.tag}
        title={entry.data.title}
        description={entry.data.description}
        url={entry.data.url}
      />
    ))}
  </section>

  <!-- CONTACT -->
  <section id="contact" class="contact">
    <h2 class="contact__h2">Say hello.</h2>
    <p class="contact__body">
      For conversations about AI systems, product engineering, or anything in the log.
    </p>
    <div class="contact__links">
      <a href="mailto:nenglert@gmail.com">Email</a>
      <a href="https://github.com/nathanenglert">GitHub</a>
      <a href="https://twitter.com/nathanenglert">Twitter</a>
      <a href="/rss.xml">RSS</a>
    </div>
    <footer class="site-footer">
      <span>Nathan Englert &middot; Since 2010</span>
      <span>Updated as things ship</span>
    </footer>
  </section>
</Base>
